<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gallery Locked - WhiteTake</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/Admin/assets/css/style.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; display: flex; align-items: center; justify-content: center; height: 100vh; }
        .lock-container { max-width: 400px; width: 100%; text-align: center; background: white; padding: 40px 30px; border-radius: 16px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
    </style>
</head>
<body>
    <div class="lock-container">
        <div class="mb-4">
             <i class="bi bi-shield-lock" style="font-size: 4rem; color: #333;"></i>
        </div>
        <h4 class="mb-2 fw-bold">Enter Access Code</h4>
        <p class="text-muted small mb-4">This gallery is password protected. Please enter the access code sent by WhiteTake Films.</p>
        
        <% if (error) { %>
            <div class="alert alert-danger py-2 small"><%= error %></div>
        <% } %>

        <form method="POST" action="/Admin/client/gallery.php">
            <div class="mb-3">
                <input type="password" name="access_code" class="form-control text-center" placeholder="••••••" required autofocus style="font-size: 1.5rem; letter-spacing: 0.3rem;">
            </div>
            <button type="submit" class="btn btn-dark w-100 rounded-pill py-2 fw-bold">Unlock Gallery</button>
        </form>
    </div>
</body>
</html>
