<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - WhiteTake Films Admin Panel</title>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;600;900&display=swap" rel="stylesheet">
    <!-- FontAwesome icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body {
            font-family: 'Mulish', sans-serif;
            background-color: #0c0c0c;
            color: #ececec;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }
        
        /* Sidebar Styles */
        .sidebar {
            width: 260px;
            background-color: #000;
            border-right: 1px solid #1a1a1a;
            display: flex;
            flex-direction: column;
            padding: 30px 20px;
            flex-shrink: 0;
            z-index: 1000;
        }
        .logo-container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 40px;
        }
        .logo {
            font-size: 24px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: -1.5px;
            color: #fff;
            text-align: center;
            flex-grow: 1;
        }
        .logo span {
            font-weight: 300;
            color: #aaa;
        }
        .sidebar-close {
            display: none;
            background: none;
            border: none;
            color: #fff;
            font-size: 20px;
            cursor: pointer;
        }
        .menu-title {
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
            color: #555;
            letter-spacing: 1.5px;
            margin-bottom: 15px;
            padding-left: 10px;
        }
        .menu-list {
            list-style: none;
            margin-bottom: 30px;
        }
        .menu-item a {
            display: flex;
            align-items: center;
            padding: 12px 15px;
            color: #aaa;
            text-decoration: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 5px;
            transition: all 0.3s;
        }
        .menu-item a:hover, .menu-item.active a {
            background-color: #111;
            color: #fff;
        }
        .logout-btn {
            margin-top: auto;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 12px;
            background-color: #ff4a4a;
            color: #fff;
            border-radius: 8px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 900;
            text-transform: uppercase;
            text-align: center;
            transition: opacity 0.3s;
        }
        .logout-btn:hover {
            opacity: 0.9;
        }
        
        /* Content Area */
        .content-area {
            flex-grow: 1;
            padding: 40px;
            overflow-y: auto;
        }
        .page-header {
            margin-bottom: 40px;
            border-bottom: 1px solid #1a1a1a;
            padding-bottom: 20px;
        }
        .page-header h1 {
            font-size: 32px;
            font-weight: 900;
            color: #fff;
            letter-spacing: -1px;
        }
        .page-header p {
            font-size: 14px;
            font-weight: 300;
            color: #888;
            margin-top: 5px;
        }
        
        /* Grid Section Styles */
        .sections-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 30px;
        }
        .section-card {
            background-color: #111;
            border: 1px solid #1c1c1c;
            border-radius: 16px;
            padding: 25px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            transition: transform 0.3s;
        }
        .section-card:hover {
            transform: translateY(-2px);
        }
        .section-card-title {
            font-size: 16px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #fff;
            border-bottom: 1px solid #222;
            padding-bottom: 10px;
        }
        .img-preview {
            width: 100%;
            height: 250px;
            background-color: #000;
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #222;
            position: relative;
        }
        .img-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .img-preview .no-img {
            color: #555;
            font-size: 14px;
            font-weight: 300;
        }
        .upload-form {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        .file-input-wrapper {
            position: relative;
            width: 100%;
            height: 48px;
            background-color: #000;
            border: 1px dashed #333;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: border-color 0.3s;
        }
        .file-input-wrapper:hover {
            border-color: #666;
        }
        .file-input-wrapper input[type="file"] {
            position: absolute;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
        }
        .file-input-label {
            font-size: 13px;
            color: #aaa;
            font-weight: 600;
        }
        .upload-btn {
            background-color: #fff;
            color: #000;
            border: none;
            padding: 12px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 900;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s;
        }
        .upload-btn:hover {
            background-color: #ccc;
        }
        
        .progress-bar-container {
            width: 100%;
            height: 4px;
            background-color: #222;
            border-radius: 2px;
            display: none;
            overflow: hidden;
        }
        .progress-bar {
            width: 0%;
            height: 100%;
            background-color: #fff;
            transition: width 0.3s;
        }
        .upload-status {
            font-size: 12px;
            font-weight: 300;
            text-align: center;
        }
        .upload-status.success {
            color: #4aff4a;
        }
        .upload-status.error {
            color: #ff4a4a;
        }
        
        .size-info {
            font-size: 11px;
            color: #555;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: -5px;
        }

        /* Mobile Header */
        .mobile-header {
            display: none;
            align-items: center;
            justify-content: space-between;
            background-color: #000;
            padding: 15px 20px;
            border-bottom: 1px solid #1a1a1a;
            position: sticky;
            top: 0;
            z-index: 999;
        }
        .mobile-menu-toggle {
            background: none;
            border: none;
            color: #fff;
            font-size: 20px;
            cursor: pointer;
        }
        .mobile-header .logo {
            font-size: 20px;
            margin-bottom: 0;
            text-align: right;
            flex-grow: 0;
        }

        /* Sidebar Overlay */
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.75);
            backdrop-filter: blur(4px);
            z-index: 998;
        }

        /* Responsive Breakpoints */
        @media (max-width: 991px) {
            body {
                flex-direction: column;
                height: auto;
                overflow: initial;
            }
            .sidebar {
                position: fixed;
                top: 0;
                left: -280px;
                width: 280px;
                height: 100vh;
                transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                box-shadow: 5px 0 25px rgba(0,0,0,0.5);
            }
            .sidebar.active {
                left: 0;
            }
            .sidebar.active ~ .sidebar-overlay {
                display: block;
            }
            .sidebar-close {
                display: block;
            }
            .mobile-header {
                display: flex;
            }
            .content-area {
                padding: 20px;
                overflow-y: initial;
            }
            .page-header {
                margin-bottom: 25px;
            }
            .page-header h1 {
                font-size: 26px;
            }
            .sections-container {
                grid-template-columns: repeat(2, 1fr);
                gap: 20px;
            }
        }

        @media (max-width: 767px) {
            .sections-container {
                grid-template-columns: 1fr;
            }
            .page-header h1 {
                font-size: 22px;
            }
        }
    </style>
</head>
<body>
    <!-- Mobile Header -->
    <div class="mobile-header">
        <button class="mobile-menu-toggle" onclick="toggleSidebar()">
            <i class="fa-solid fa-bars"></i>
        </button>
        <div class="logo">WhiteTake<span>Films</span></div>
    </div>

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="logo-container">
            <div class="logo">WhiteTake<span>Films</span></div>
            <button class="sidebar-close" onclick="toggleSidebar()">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        
        <div class="menu-title">Select Page</div>
        <ul class="menu-list">
            <li class="menu-item active">
                <a href="#home">Home Page</a>
            </li>
            <!-- Submenu Items Grouped Under Home Page -->
            <li class="menu-item submenu-item" style="padding-left: 20px;">
                <a href="#instagram-feed" style="display: flex; align-items: center; gap: 8px; font-size: 13px; padding: 8px 12px;">
                    <i class="fa-brands fa-instagram" style="font-size: 13px;"></i> Instagram Feed
                </a>
            </li>
            <li class="menu-item submenu-item" style="padding-left: 20px;">
                <a href="#youtube-feed" style="display: flex; align-items: center; gap: 8px; font-size: 13px; padding: 8px 12px;">
                    <i class="fa-brands fa-youtube" style="font-size: 13px; color: #ff0000;"></i> YouTube Feed
                </a>
            </li>
            <li class="menu-item submenu-item" style="padding-left: 20px;">
                <a href="#favorite-moments" style="display: flex; align-items: center; gap: 8px; font-size: 13px; padding: 8px 12px;">
                    <i class="fa-solid fa-heart" style="font-size: 13px; color: #e1306c;"></i> Favorite Moments
                </a>
            </li>
            <li class="menu-item" style="margin-top: 15px;">
                <a href="/pannl/Image_admin" style="display: flex; align-items: center; gap: 8px;">
                    <i class="fa-solid fa-images" style="font-size: 14px;"></i> All Page Images
                </a>
            </li>
        </ul>
        
        <a href="/pannl/logout.php" class="logout-btn">Sign Out</a>
    </div>
    <div class="sidebar-overlay" onclick="toggleSidebar()"></div>
    
    <!-- Content Area -->
    <div class="content-area">
        <div class="page-header" id="home">
            <h1>Home Page Editor</h1>
            <p>Upload new images to sections. Images will be automatically cropped and resized to exactly 1080 X 1350 format.</p>
        </div>
        
        <div class="sections-container">
            <% if (grouped_images && grouped_images['home']) { %>
                <% grouped_images['home'].filter(img => !img.section_key.startsWith('favorite_') && !img.section_key.startsWith('story_')).forEach(function(img) { 
                    const labels = {
                        'intimate_1': 'Behind the Lens Card 1 (Krishna & Connor)',
                        'intimate_2': 'Behind the Lens Card 2 (Sai & Aishwarya)',
                        'intimate_3': 'Behind the Lens Card 3 (Reshma & Rajiv)',
                        'intimate_logo_bg': 'Logo Circle Background',
                        'feature_image': 'Features Section Card Image',
                        'feature_video': 'Features Section YouTube Video Link'
                    };
                    const label = labels[img.section_key] || img.section_key;
                    
                    let preview_src = img.image_path;
                    if (!preview_src.match(/^https?:\/\//) && !preview_src.startsWith('data:')) {
                        preview_src = '/' + preview_src;
                    }
                %>
                    <% if (img.section_key === 'feature_video') { %>
                        <!-- Text Link Editor for Feature Video -->
                        <div class="section-card" id="card-<%= img.section_key %>">
                            <div class="section-card-title" style="display: flex; justify-content: space-between; align-items: center;">
                                <span><%= label %></span>
                                <span style="background: #222; color: #c5a880; font-size: 11px; padding: 3px 8px; border-radius: 12px; border: 1px solid #333; text-transform: none;"><%= img.section_key %></span>
                            </div>
                            
                            <div style="background-color: #050505; border: 1px solid #222; border-radius: 8px; padding: 12px; font-size: 13px; color: #888;">
                                <div style="margin-bottom: 5px; font-weight: 600; color: #aaa;">Current Link:</div>
                                <div id="url-text-<%= img.section_key %>" style="word-break: break-all; font-family: monospace; max-height: 80px; overflow-y: auto;"><%= img.image_path %></div>
                            </div>

                            <form class="text-update-form" data-key="<%= img.section_key %>" style="display: flex; flex-direction: column; gap: 10px;">
                                <textarea name="text_value" placeholder="Paste YouTube Video Link" required rows="3"
                                          style="background: #000; border: 1px solid #333; color: #fff; padding: 10px 12px; border-radius: 8px; font-family: inherit; font-size: 13px; resize: vertical;"><%= img.image_path %></textarea>
                                
                                <div class="upload-status" id="text-status-<%= img.section_key %>" style="font-size: 12px; text-align: center;"></div>
                                
                                <button type="submit" class="upload-btn" style="background: #ff0000; color: #fff;">Save Link</button>
                            </form>
                        </div>
                    <% } else { %>
                        <!-- Standard Image Card -->
                        <div class="section-card" id="card-<%= img.section_key %>">
                            <div class="section-card-title" style="display: flex; justify-content: space-between; align-items: center;">
                                <span><%= label %></span>
                                <span style="background: #222; color: #c5a880; font-size: 11px; padding: 3px 8px; border-radius: 12px; border: 1px solid #333; text-transform: none;"><%= img.section_key %></span>
                            </div>
                            
                            <div class="img-preview">
                                <img src="<%= preview_src %>" alt="Preview" id="preview-img-<%= img.section_key %>">
                            </div>
                            
                            <div class="size-info">Output Size: 1080 x 1350 px</div>
                            
                            <form class="upload-form" data-key="<%= img.section_key %>">
                                <div class="file-input-wrapper">
                                    <span class="file-input-label" id="file-label-<%= img.section_key %>">Choose Image</span>
                                    <input type="file" name="image" accept="image/*" required onchange="handleFileSelect(this, '<%= img.section_key %>')">
                                </div>
                                
                                <div class="progress-bar-container" id="progress-container-<%= img.section_key %>">
                                    <div class="progress-bar" id="progress-bar-<%= img.section_key %>"></div>
                                </div>
                                
                                <div class="upload-status" id="status-<%= img.section_key %>"></div>
                                
                                <button type="submit" class="upload-btn">Upload & Crop</button>
                            </form>
                        </div>
                    <% } %>
                <% }) %>
            <% } %>
        </div>

        <!-- ── Featured Stories Editor Section ── -->
        <div class="page-header" id="featured-stories" style="margin-top: 60px; border-top: 1px solid #1a1a1a; padding-top: 40px;">
            <h1>Featured Stories (Intimate Weddings)</h1>
            <p>Edit the images, names, taglines, description, and link for the 10 featured stories at the bottom of the home page.</p>
        </div>

        <div class="sections-container" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-bottom: 40px;">
            <% 
                for (let i = 1; i <= 10; i++) {
                    const imgObj = grouped_images['home'].find(img => img.section_key === `story_img_${i}`) || { image_path: '' };
                    const nameObj = grouped_images['home'].find(img => img.section_key === `story_names_${i}`) || { image_path: '' };
                    const subObj = grouped_images['home'].find(img => img.section_key === `story_subtitle_${i}`) || { image_path: '' };
                    const descObj = grouped_images['home'].find(img => img.section_key === `story_desc_${i}`) || { image_path: '' };
                    const linkObj = grouped_images['home'].find(img => img.section_key === `story_link_${i}`) || { image_path: '' };

                    let preview_src = imgObj.image_path;
                    if (preview_src && !preview_src.match(/^https?:\/\//) && !preview_src.startsWith('data:')) {
                        preview_src = '/' + preview_src;
                    } else if (!preview_src) {
                        preview_src = 'pic/Your Love, Our Passion/pic' + i + '.webp';
                    }
            %>
                <div class="section-card" style="background: #111; border: 1px solid #222; border-radius: 12px; padding: 20px;">
                    <h3 style="font-size: 16px; font-weight: 600; color: #fff; margin-bottom: 15px; border-bottom: 1px solid #222; padding-bottom: 8px; display: flex; justify-content: space-between; align-items: center;">
                        <span>Story Card #<%= i %></span>
                        <span style="font-size: 11px; background: #222; color: #c5a880; padding: 2px 8px; border-radius: 8px;">Story <%= i %></span>
                    </h3>

                    <!-- Image Upload -->
                    <div class="img-preview" style="height: 180px; margin-bottom: 12px; border-radius: 8px; overflow: hidden; background: #000; display: flex; align-items: center; justify-content: center;">
                        <img src="<%= preview_src %>" alt="Preview" id="preview-img-story_img_<%= i %>" style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <div class="size-info" style="font-size: 11px; color: #888; margin-bottom: 10px;">Output: 1080 x 1080 px (Square)</div>

                    <form class="upload-form" data-key="story_img_<%= i %>" style="margin-bottom: 20px;">
                        <div class="file-input-wrapper">
                            <span class="file-input-label" id="file-label-story_img_<%= i %>">Choose Story Image</span>
                            <input type="file" name="image" accept="image/*" required onchange="handleFileSelect(this, 'story_img_<%= i %>')">
                        </div>
                        <div class="progress-bar-container" id="progress-container-story_img_<%= i %>" style="display:none;">
                            <div class="progress-bar" id="progress-bar-story_img_<%= i %>"></div>
                        </div>
                        <div class="upload-status" id="status-story_img_<%= i %>"></div>
                        <button type="submit" class="upload-btn">Upload Image</button>
                    </form>

                    <!-- Text Fields Form -->
                    <div style="border-top: 1px solid #222; padding-top: 15px;">
                        <h4 style="font-size: 13px; color: #aaa; margin-bottom: 12px;">Card Details</h4>

                        <!-- Names -->
                        <form class="text-update-form" data-key="story_names_<%= i %>" style="margin-bottom: 12px;">
                            <label style="font-size: 11px; color: #777; display: block; margin-bottom: 4px;">Couple Names (e.g. ANEENA & GARY)</label>
                            <div style="display: flex; gap: 8px;">
                                <input type="text" name="text_value" value="<%= nameObj.image_path %>" required 
                                       style="flex: 1; background: #000; border: 1px solid #333; color: #fff; padding: 6px 10px; border-radius: 6px; font-size: 13px;">
                                <button type="submit" class="upload-btn" style="margin: 0; padding: 6px 12px; font-size: 11px; width: auto;">Save</button>
                            </div>
                            <div class="upload-status" id="text-status-story_names_<%= i %>" style="font-size: 10px; margin-top: 2px;"></div>
                        </form>

                        <!-- Tagline -->
                        <form class="text-update-form" data-key="story_subtitle_<%= i %>" style="margin-bottom: 12px;">
                            <label style="font-size: 11px; color: #777; display: block; margin-bottom: 4px;">Tagline / Subtitle</label>
                            <div style="display: flex; gap: 8px;">
                                <input type="text" name="text_value" value="<%= subObj.image_path %>" required 
                                       style="flex: 1; background: #000; border: 1px solid #333; color: #fff; padding: 6px 10px; border-radius: 6px; font-size: 13px;">
                                <button type="submit" class="upload-btn" style="margin: 0; padding: 6px 12px; font-size: 11px; width: auto;">Save</button>
                            </div>
                            <div class="upload-status" id="text-status-story_subtitle_<%= i %>" style="font-size: 10px; margin-top: 2px;"></div>
                        </form>

                        <!-- Link -->
                        <form class="text-update-form" data-key="story_link_<%= i %>" style="margin-bottom: 12px;">
                            <label style="font-size: 11px; color: #777; display: block; margin-bottom: 4px;">Read More Link URL (e.g. /gallery.html or #)</label>
                            <div style="display: flex; gap: 8px;">
                                <input type="text" name="text_value" value="<%= linkObj.image_path %>" required 
                                       style="flex: 1; background: #000; border: 1px solid #333; color: #fff; padding: 6px 10px; border-radius: 6px; font-size: 13px;">
                                <button type="submit" class="upload-btn" style="margin: 0; padding: 6px 12px; font-size: 11px; width: auto;">Save</button>
                            </div>
                            <div class="upload-status" id="text-status-story_link_<%= i %>" style="font-size: 10px; margin-top: 2px;"></div>
                        </form>

                        <!-- Description -->
                        <form class="text-update-form" data-key="story_desc_<%= i %>">
                            <label style="font-size: 11px; color: #777; display: block; margin-bottom: 4px;">Story Description</label>
                            <textarea name="text_value" required rows="4" 
                                      style="width: 100%; background: #000; border: 1px solid #333; color: #fff; padding: 8px 10px; border-radius: 6px; font-size: 12px; resize: vertical; line-height: 1.4; margin-bottom: 6px;"><%= descObj.image_path %></textarea>
                            <button type="submit" class="upload-btn" style="margin: 0; width: 100%; font-size: 12px;">Save Description</button>
                            <div class="upload-status" id="text-status-story_desc_<%= i %>" style="font-size: 10px; margin-top: 2px;"></div>
                        </form>
                    </div>
                </div>
            <% } %>
        </div>

        <!-- ── Our Favorite Moments — Modal Gallery Manager ── -->
        <div class="page-header" id="favorite-moments" style="margin-top: 60px; border-top: 1px solid #1a1a1a; padding-top: 40px;">
            <h1>Our Favorite Moments</h1>
        </div>

        <!-- Slot Grid -->
        <div id="fav-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; margin-bottom: 60px;">
            <% if (grouped_images && grouped_images['home']) {
                const favImages = grouped_images['home'].filter(img => img.section_key.startsWith('favorite_'));
                favImages.forEach(function(img) {
                    let preview_src = img.image_path;
                    if (preview_src && !preview_src.match(/^https?:\/\//) && !preview_src.startsWith('data:')) {
                        preview_src = '/' + preview_src;
                    }
                    const slotNum = img.section_key.replace('favorite_', '');
                    const isFilled = preview_src && preview_src.length > 1;
            %>
                <div class="fav-thumb"
                     id="fav-thumb-<%= img.section_key %>"
                     onclick="openFavModal('<%= img.section_key %>', '<%= slotNum %>', <%= isFilled ? 'true' : 'false' %>)"
                     style="aspect-ratio:1/1; border-radius:10px; overflow:hidden; position:relative; cursor:pointer; background:#111; border:1px solid #1c1c1c; transition:border-color 0.2s;">
                    <% if (isFilled) { %>
                        <img src="<%= preview_src %>" id="fav-thumb-img-<%= img.section_key %>" alt="Slot <%= slotNum %>" style="width:100%;height:100%;object-fit:cover;display:block;">
                        <div style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,0.7));padding:6px 6px 5px;display:flex;justify-content:space-between;align-items:center;">
                            <span style="font-size:10px;font-weight:700;color:#fff;">#<%= slotNum %></span>
                            <i class="fa fa-check-circle" style="font-size:11px;color:#4aff4a;"></i>
                        </div>
                    <% } else { %>
                        <div style="width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;color:#444;">
                            <i class="fa fa-plus" style="font-size:20px;"></i>
                            <span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">#<%= slotNum %></span>
                        </div>
                    <% } %>
                </div>
            <% }); } %>
        </div>

        <!-- Upload Modal -->
        <div id="fav-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9999;align-items:center;justify-content:center;padding:20px;" onclick="closeFavModal(event)">
            <div style="background:#111;border:1px solid #222;border-radius:20px;width:100%;max-width:420px;padding:30px;position:relative;" onclick="event.stopPropagation()">
                <!-- Close -->
                <button onclick="closeFavModal()" style="position:absolute;top:15px;right:15px;background:none;border:none;color:#666;font-size:22px;cursor:pointer;line-height:1;">&times;</button>

                <div id="fav-modal-title" style="font-size:16px;font-weight:900;color:#fff;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Slot #1</div>
                <div style="font-size:12px;color:#555;margin-bottom:20px;">1080 × 1080 px · Max 10 MB</div>

                <!-- Image preview -->
                <div id="fav-modal-preview-wrap" style="width:100%;aspect-ratio:1/1;border-radius:12px;overflow:hidden;background:#000;border:1px solid #222;margin-bottom:20px;position:relative;">
                    <img id="fav-modal-img" src="" alt="" style="width:100%;height:100%;object-fit:cover;display:none;">
                    <div id="fav-modal-empty-icon" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:10px;color:#333;">
                        <i class="fa fa-image" style="font-size:48px;"></i>
                        <span style="font-size:13px;color:#555;">No image uploaded yet</span>
                    </div>
                    <!-- Progress overlay -->
                    <div id="fav-modal-progress" style="display:none;position:absolute;inset:0;background:rgba(0,0,0,0.8);flex-direction:column;align-items:center;justify-content:center;gap:14px;border-radius:12px;">
                        <div style="width:70%;height:4px;background:#333;border-radius:4px;overflow:hidden;">
                            <div id="fav-modal-bar" style="width:0%;height:100%;background:#fff;transition:width 0.2s;border-radius:4px;"></div>
                        </div>
                        <span id="fav-modal-status" style="font-size:13px;color:#aaa;">Uploading…</span>
                    </div>
                </div>

                <!-- Hidden file input -->
                <input type="file" id="fav-modal-file-input" accept="image/*" style="display:none;" onchange="handleFavModalUpload(this)">

                <!-- Action buttons -->
                <div style="display:flex;flex-direction:column;gap:10px;">
                    <button id="fav-modal-upload-btn" onclick="document.getElementById('fav-modal-file-input').click()"
                            style="width:100%;padding:14px;background:#fff;color:#000;border:none;border-radius:10px;font-size:14px;font-weight:900;text-transform:uppercase;letter-spacing:0.5px;cursor:pointer;">
                        <i class="fa fa-upload" style="margin-right:8px;"></i>
                        <span id="fav-modal-upload-label">Upload Image</span>
                    </button>
                    <button id="fav-modal-delete-btn" onclick="handleFavModalDelete()"
                            style="display:none;width:100%;padding:14px;background:transparent;color:#ff4a4a;border:1px solid #ff4a4a;border-radius:10px;font-size:14px;font-weight:900;text-transform:uppercase;letter-spacing:0.5px;cursor:pointer;">
                        <i class="fa fa-trash" style="margin-right:8px;"></i> Remove Image
                    </button>
                </div>
            </div>
        </div>

        <style>
            .fav-thumb:hover { border-color: #444 !important; }
        </style>

        <!-- Instagram Feed Editor Section -->
        <div class="page-header" id="instagram-feed" style="margin-top: 0px; border-top: 1px solid #1a1a1a; padding-top: 40px;">
            <h1>Instagram Feed Editor (Photos)</h1>
            <p>Manage the 3x2 grid of Instagram post photos. Enter standard Instagram post URLs or Blockquote Embed codes.</p>
        </div>

        <div class="sections-container" style="margin-bottom: 40px;">
            <% if (typeof feeds !== 'undefined' && feeds) { 
                const photoFeeds = feeds.filter(f => f.feed_key.startsWith('feed_'));
            %>
                <% photoFeeds.forEach(function(feed, index) { 
                    const feedLabels = {
                        'feed_1': 'Photo Slot 1 (Row 1, Col 1)',
                        'feed_2': 'Photo Slot 2 (Row 1, Col 2)',
                        'feed_3': 'Photo Slot 3 (Row 1, Col 3)',
                        'feed_4': 'Photo Slot 4 (Row 2, Col 1)',
                        'feed_5': 'Photo Slot 5 (Row 2, Col 2)',
                        'feed_6': 'Photo Slot 6 (Row 2, Col 3)'
                    };
                    const label = feedLabels[feed.feed_key] || `Custom Photo Slot (${feed.feed_key.replace('feed_', '')})`;
                %>
                    <div class="section-card" id="feed-card-<%= feed.feed_key %>" style="gap: 15px;">
                        <div class="section-card-title" style="display: flex; align-items: center; gap: 8px;">
                            <i class="fa-brands fa-instagram" style="color: #e1306c;"></i> <%= label %>
                        </div>
                        
                        <div style="background-color: #050505; border: 1px solid #222; border-radius: 8px; padding: 12px; font-size: 13px; color: #888;">
                            <div style="margin-bottom: 5px; font-weight: 600; color: #aaa;">Current Link / Embed Code:</div>
                            <div id="url-text-<%= feed.feed_key %>" style="word-break: break-all; font-family: monospace; max-height: 80px; overflow-y: auto;"><%= feed.post_url %></div>
                        </div>

                        <form class="feed-update-form" data-key="<%= feed.feed_key %>" style="display: flex; flex-direction: column; gap: 10px;">
                            <textarea name="post_url" placeholder="Paste Instagram Link or Embed HTML Code" required rows="3"
                                      style="background: #000; border: 1px solid #333; color: #fff; padding: 10px 12px; border-radius: 8px; font-family: inherit; font-size: 13px; resize: vertical;"><%= feed.post_url %></textarea>
                            
                            <div class="upload-status" id="feed-status-<%= feed.feed_key %>" style="font-size: 12px; text-align: center;"></div>
                            
                            <div style="display: flex; gap: 10px;">
                                <button type="submit" class="upload-btn" style="background: #e1306c; color: #fff; flex-grow: 1;">Save Link</button>
                                <button type="button" class="upload-btn" onclick="handleDeleteSlot('<%= feed.feed_key %>')" style="background: #222; color: #ff4a4a; border: 1px solid #333; padding: 12px 15px;"><i class="fa fa-trash"></i></button>
                            </div>
                        </form>
                    </div>
                <% }) %>
            <% } %>

            <!-- Add New Photo Slot Card -->
            <div class="section-card" id="add-card-photo" style="border: 2px dashed #333; min-height: 250px; display: flex; flex-direction: column; justify-content: center; background: transparent;">
                <div id="add-trigger-photo" style="text-align: center; color: #aaa; cursor: pointer;" onclick="toggleAddForm('photo', true)">
                    <i class="fa fa-plus-circle" style="font-size: 40px; margin-bottom: 10px; color: #e1306c;"></i>
                    <div style="font-weight: 900; text-transform: uppercase; font-size: 14px; letter-spacing: 0.5px;">Add New Photo Slot</div>
                </div>
                <div id="add-form-photo" style="display: none; flex-direction: column; gap: 12px; height: 100%;">
                    <div class="section-card-title" style="display: flex; justify-content: space-between; align-items: center;">
                        <span>Add Photo Slot</span>
                        <i class="fa-solid fa-xmark" style="cursor: pointer; color: #888;" onclick="toggleAddForm('photo', false)"></i>
                    </div>
                    <form onsubmit="handleAddSlot(event, 'photo')" style="display: flex; flex-direction: column; gap: 10px; flex-grow: 1;">
                        <textarea name="post_url" placeholder="Paste Instagram Link or Embed HTML Code" required rows="3"
                                  style="background: #000; border: 1px solid #333; color: #fff; padding: 10px 12px; border-radius: 8px; font-family: inherit; font-size: 13px; resize: vertical; flex-grow: 1;"></textarea>
                        <button type="submit" class="upload-btn" style="background: #e1306c; color: #fff;">Add Slot</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- YouTube Video Editor Section -->
        <div class="page-header" id="youtube-feed" style="margin-top: 40px; border-top: 1px solid #1a1a1a; padding-top: 40px;">
            <h1>YouTube Feed Editor</h1>
            <p>Manage the 3x2 grid of YouTube Videos. Enter standard YouTube video URLs (e.g. <code>https://www.youtube.com/watch?v=F384n1wXQoY</code>).</p>
        </div>

        <div class="sections-container" style="margin-bottom: 60px;">
            <% if (typeof feeds !== 'undefined' && feeds) { 
                const ytFeeds = feeds.filter(f => f.feed_key.startsWith('yt_'));
            %>
                <% ytFeeds.forEach(function(feed, index) { 
                    const ytLabels = {
                        'yt_1': 'YouTube Slot 1 (Row 1, Col 1)',
                        'yt_2': 'YouTube Slot 2 (Row 1, Col 2)',
                        'yt_3': 'YouTube Slot 3 (Row 1, Col 3)',
                        'yt_4': 'YouTube Slot 4 (Row 2, Col 1)',
                        'yt_5': 'YouTube Slot 5 (Row 2, Col 2)',
                        'yt_6': 'YouTube Slot 6 (Row 2, Col 3)'
                    };
                    const label = ytLabels[feed.feed_key] || `Custom YouTube Slot (${feed.feed_key.replace('yt_', '')})`;
                %>
                    <div class="section-card" id="feed-card-<%= feed.feed_key %>" style="gap: 15px;">
                        <div class="section-card-title" style="display: flex; align-items: center; gap: 8px;">
                            <i class="fa-brands fa-youtube" style="color: #ff0000;"></i> <%= label %>
                        </div>
                        
                        <div style="background-color: #050505; border: 1px solid #222; border-radius: 8px; padding: 12px; font-size: 13px; color: #888;">
                            <div style="margin-bottom: 5px; font-weight: 600; color: #aaa;">Current Link:</div>
                            <div id="url-text-<%= feed.feed_key %>" style="word-break: break-all; font-family: monospace; max-height: 80px; overflow-y: auto;"><%= feed.post_url %></div>
                        </div>

                        <form class="feed-update-form" data-key="<%= feed.feed_key %>" style="display: flex; flex-direction: column; gap: 10px;">
                            <textarea name="post_url" placeholder="Paste YouTube Video Link" required rows="3"
                                      style="background: #000; border: 1px solid #333; color: #fff; padding: 10px 12px; border-radius: 8px; font-family: inherit; font-size: 13px; resize: vertical;"><%= feed.post_url %></textarea>
                            
                            <div class="upload-status" id="feed-status-<%= feed.feed_key %>" style="font-size: 12px; text-align: center;"></div>
                            
                            <div style="display: flex; gap: 10px;">
                                <button type="submit" class="upload-btn" style="background: #ff0000; color: #fff; flex-grow: 1;">Save Link</button>
                                <button type="button" class="upload-btn" onclick="handleDeleteSlot('<%= feed.feed_key %>')" style="background: #222; color: #ff4a4a; border: 1px solid #333; padding: 12px 15px;"><i class="fa fa-trash"></i></button>
                            </div>
                        </form>
                    </div>
                <% }) %>
            <% } %>

            <!-- Add New YouTube Slot Card -->
            <div class="section-card" id="add-card-yt" style="border: 2px dashed #333; min-height: 250px; display: flex; flex-direction: column; justify-content: center; background: transparent;">
                <div id="add-trigger-yt" style="text-align: center; color: #aaa; cursor: pointer;" onclick="toggleAddForm('yt', true)">
                    <i class="fa fa-plus-circle" style="font-size: 40px; margin-bottom: 10px; color: #ff0000;"></i>
                    <div style="font-weight: 900; text-transform: uppercase; font-size: 14px; letter-spacing: 0.5px;">Add New YouTube Slot</div>
                </div>
                <div id="add-form-yt" style="display: none; flex-direction: column; gap: 12px; height: 100%;">
                    <div class="section-card-title" style="display: flex; justify-content: space-between; align-items: center;">
                        <span>Add YouTube Slot</span>
                        <i class="fa-solid fa-xmark" style="cursor: pointer; color: #888;" onclick="toggleAddForm('yt', false)"></i>
                    </div>
                    <form onsubmit="handleAddSlot(event, 'yt')" style="display: flex; flex-direction: column; gap: 10px; flex-grow: 1;">
                        <textarea name="post_url" placeholder="Paste YouTube Video Link" required rows="3"
                                  style="background: #000; border: 1px solid #333; color: #fff; padding: 10px 12px; border-radius: 8px; font-family: inherit; font-size: 13px; resize: vertical; flex-grow: 1;"></textarea>
                        <button type="submit" class="upload-btn" style="background: #ff0000; color: #fff;">Add Slot</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        // ── Favorite Moments Modal State ──
        let _favCurrentKey   = null;
        let _favCurrentSlot  = null;
        let _favCurrentFilled = false;

        function openFavModal(key, slotNum, isFilled) {
            _favCurrentKey    = key;
            _favCurrentSlot   = slotNum;
            _favCurrentFilled = isFilled;

            // Update modal title
            document.getElementById('fav-modal-title').textContent = 'Slot #' + slotNum;

            // Show/hide image
            const img       = document.getElementById('fav-modal-img');
            const emptyIcon = document.getElementById('fav-modal-empty-icon');
            const delBtn    = document.getElementById('fav-modal-delete-btn');
            const upLabel   = document.getElementById('fav-modal-upload-label');

            if (isFilled) {
                const thumbImg = document.getElementById('fav-thumb-img-' + key);
                img.src = thumbImg ? thumbImg.src : '';
                img.style.display = 'block';
                emptyIcon.style.display = 'none';
                delBtn.style.display = 'block';
                upLabel.textContent = 'Replace Image';
            } else {
                img.src = '';
                img.style.display = 'none';
                emptyIcon.style.display = 'flex';
                delBtn.style.display = 'none';
                upLabel.textContent = 'Upload Image';
            }

            // Reset progress
            document.getElementById('fav-modal-progress').style.display = 'none';
            document.getElementById('fav-modal-bar').style.width = '0%';

            // Reset file input
            document.getElementById('fav-modal-file-input').value = '';

            // Show modal
            const modal = document.getElementById('fav-modal');
            modal.style.display = 'flex';
        }

        function closeFavModal(e) {
            if (e && e.target !== document.getElementById('fav-modal')) return;
            document.getElementById('fav-modal').style.display = 'none';
            _favCurrentKey = null;
        }

        // Close button calls this directly
        document.querySelector && document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('fav-modal').addEventListener('click', function(e) {
                if (e.target === this) {
                    this.style.display = 'none';
                    _favCurrentKey = null;
                }
            });
        });

        function handleFavModalUpload(input) {
            if (!_favCurrentKey || !input.files || !input.files[0]) return;
            const file = input.files[0];

            if (file.size > 10 * 1024 * 1024) {
                alert('This image exceeds the 10 MB size limit. Please choose a smaller file.');
                input.value = '';
                return;
            }

            const progress   = document.getElementById('fav-modal-progress');
            const bar        = document.getElementById('fav-modal-bar');
            const status     = document.getElementById('fav-modal-status');

            progress.style.display = 'flex';
            bar.style.width = '0%';
            status.textContent = 'Uploading…';

            const formData = new FormData();
            formData.append('image', file);
            formData.append('section_key', _favCurrentKey);

            const xhr = new XMLHttpRequest();
            xhr.open('POST', '/pannl/upload.php', true);

            xhr.upload.addEventListener('progress', function(e) {
                if (e.lengthComputable) {
                    bar.style.width = Math.round((e.loaded / e.total) * 100) + '%';
                }
            });

            xhr.onreadystatechange = function() {
                if (xhr.readyState !== XMLHttpRequest.DONE) return;
                progress.style.display = 'none';
                try {
                    const res = JSON.parse(xhr.responseText);
                    if (res.success) {
                        const key     = _favCurrentKey;
                        const slotNum = _favCurrentSlot;
                        const src     = res.path + '?t=' + Date.now();

                        // Update modal image
                        const img = document.getElementById('fav-modal-img');
                        img.src = src;
                        img.style.display = 'block';
                        document.getElementById('fav-modal-empty-icon').style.display = 'none';
                        document.getElementById('fav-modal-delete-btn').style.display = 'block';
                        document.getElementById('fav-modal-upload-label').textContent = 'Replace Image';

                        // Update thumbnail in grid
                        const thumb = document.getElementById('fav-thumb-' + key);
                        if (thumb) {
                            thumb.setAttribute('onclick', `openFavModal('${key}', '${slotNum}', true)`);
                            thumb.innerHTML = `
                                <img src="${src}" id="fav-thumb-img-${key}" alt="Slot ${slotNum}" style="width:100%;height:100%;object-fit:cover;display:block;">
                                <div style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,0.7));padding:6px 6px 5px;display:flex;justify-content:space-between;align-items:center;">
                                    <span style="font-size:10px;font-weight:700;color:#fff;">#${slotNum}</span>
                                    <i class="fa fa-check-circle" style="font-size:11px;color:#4aff4a;"></i>
                                </div>
                            `;
                        }
                        _favCurrentFilled = true;
                    } else {
                        alert('Upload error: ' + (res.message || 'Unknown error'));
                    }
                } catch(err) {
                    alert('Server error during upload.');
                }
                input.value = '';
            };
            xhr.send(formData);
        }

        function handleFavModalDelete() {
            if (!_favCurrentKey) return;
            if (!confirm('Remove this image? This cannot be undone.')) return;

            const key     = _favCurrentKey;
            const slotNum = _favCurrentSlot;

            fetch('/pannl/delete_image.php', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ section_key: key })
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    // Reset modal to empty state
                    document.getElementById('fav-modal-img').style.display = 'none';
                    document.getElementById('fav-modal-empty-icon').style.display = 'flex';
                    document.getElementById('fav-modal-delete-btn').style.display = 'none';
                    document.getElementById('fav-modal-upload-label').textContent = 'Upload Image';

                    // Update thumbnail
                    const thumb = document.getElementById('fav-thumb-' + key);
                    if (thumb) {
                        thumb.setAttribute('onclick', `openFavModal('${key}', '${slotNum}', false)`);
                        thumb.innerHTML = `
                            <div style="width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;color:#444;">
                                <i class="fa fa-plus" style="font-size:20px;"></i>
                                <span style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">#${slotNum}</span>
                            </div>
                        `;
                    }
                    _favCurrentFilled = false;
                    // Close modal after short delay
                    setTimeout(() => { document.getElementById('fav-modal').style.display = 'none'; }, 400);
                } else {
                    alert('Delete failed: ' + (res.message || 'Unknown error'));
                }
            })
            .catch(() => alert('Server error during delete.'));
        }

        function handleFileSelect(input, key) {
            const label = document.getElementById('file-label-' + key);
            if (input.files && input.files[0]) {
                label.innerText = input.files[0].name;
            } else {
                label.innerText = "Choose Image";
            }
        }
        
        document.querySelectorAll('.upload-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const key = this.getAttribute('data-key');
                const formData = new FormData(this);
                formData.append('section_key', key);
                
                const progressContainer = document.getElementById('progress-container-' + key);
                const progressBar = document.getElementById('progress-bar-' + key);
                const statusDiv = document.getElementById('status-' + key);
                const previewImg = document.getElementById('preview-img-' + key);
                
                // Reset status
                progressContainer.style.display = 'block';
                progressBar.style.width = '0%';
                statusDiv.className = 'upload-status';
                statusDiv.innerText = 'Processing...';
                
                const xhr = new XMLHttpRequest();
                xhr.open('POST', '/pannl/upload.php', true);
                
                xhr.upload.addEventListener('progress', function(e) {
                    if (e.lengthComputable) {
                        const percent = (e.loaded / e.total) * 100;
                        progressBar.style.width = percent + '%';
                    }
                });
                
                xhr.onreadystatechange = function() {
                    if (xhr.readyState === XMLHttpRequest.DONE) {
                        progressContainer.style.display = 'none';
                        try {
                            const res = JSON.parse(xhr.responseText);
                            if (res.success) {
                                statusDiv.className = 'upload-status success';
                                statusDiv.innerText = 'Uploaded & cropped successfully!';
                                // Refresh preview with cache-buster
                                previewImg.src = '/' + res.path + '?t=' + new Date().getTime();
                                // Reset form label
                                document.getElementById('file-label-' + key).innerText = "Choose Image";
                                form.reset();
                            } else {
                                statusDiv.className = 'upload-status error';
                                statusDiv.innerText = 'Error: ' + res.message;
                            }
                        } catch(e) {
                            statusDiv.className = 'upload-status error';
                            statusDiv.innerText = 'Upload failed. Server error.';
                        }
                    }
                };
                
                xhr.send(formData);
            });
        });

        document.querySelectorAll('.feed-update-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                const key = this.getAttribute('data-key');
                const postUrl = this.querySelector('[name="post_url"]').value;
                const statusDiv = document.getElementById('feed-status-' + key);
                const urlTextDiv = document.getElementById('url-text-' + key);
                
                statusDiv.className = 'upload-status';
                statusDiv.style.color = '#aaa';
                statusDiv.innerText = 'Saving...';
                
                fetch('/pannl/update_feed.php', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ feed_key: key, post_url: postUrl })
                })
                .then(response => response.json())
                .then(res => {
                    if (res.success) {
                        statusDiv.style.color = '#4aff4a';
                        statusDiv.innerText = 'Saved successfully!';
                        urlTextDiv.innerText = postUrl;
                        setTimeout(() => { statusDiv.innerText = ''; }, 3000);
                    } else {
                        statusDiv.style.color = '#ff4a4a';
                        statusDiv.innerText = 'Error: ' + res.message;
                    }
                })
                .catch(err => {
                    statusDiv.style.color = '#ff4a4a';
                    statusDiv.innerText = 'Failed to save. Server error.';
                });
            });
        });

        document.querySelectorAll('.text-update-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                const key = this.getAttribute('data-key');
                const textVal = this.querySelector('[name="text_value"]').value;
                const statusDiv = document.getElementById('text-status-' + key);
                const urlTextDiv = document.getElementById('url-text-' + key);
                
                statusDiv.className = 'upload-status';
                statusDiv.style.color = '#aaa';
                statusDiv.innerText = 'Saving...';
                
                fetch('/pannl/update_section_text.php', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ section_key: key, text_value: textVal })
                })
                .then(response => response.json())
                .then(res => {
                    if (res.success) {
                        statusDiv.style.color = '#4aff4a';
                        statusDiv.innerText = 'Saved successfully!';
                        if (urlTextDiv) {
                            urlTextDiv.innerText = textVal;
                        }
                        setTimeout(() => { statusDiv.innerText = ''; }, 3000);
                    } else {
                        statusDiv.style.color = '#ff4a4a';
                        statusDiv.innerText = 'Error: ' + res.message;
                    }
                })
                .catch(err => {
                    statusDiv.style.color = '#ff4a4a';
                    statusDiv.innerText = 'Failed to save. Server error.';
                });
            });
        });

        // Toggle the inline Add Form states
        function toggleAddForm(type, show) {
            const trigger = document.getElementById(`add-trigger-${type}`);
            const form = document.getElementById(`add-form-${type}`);
            if (show) {
                trigger.style.display = 'none';
                form.style.display = 'flex';
            } else {
                trigger.style.display = 'block';
                form.style.display = 'none';
                form.querySelector('form').reset();
            }
        }

        // Add slot AJAX call
        function handleAddSlot(event, type) {
            event.preventDefault();
            const form = event.target;
            const postUrl = form.querySelector('[name="post_url"]').value;
            
            fetch('/pannl/add_feed.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ type, post_url: postUrl })
            })
            .then(response => response.json())
            .then(res => {
                if (res.success) {
                    alert('New slot added successfully! Reloading panel...');
                    window.location.reload();
                } else {
                    alert('Error adding slot: ' + res.message);
                }
            })
            .catch(err => {
                console.error(err);
                alert('Server error adding slot.');
            });
        }

        // Delete slot AJAX call
        function handleDeleteSlot(feedKey) {
            if (!confirm('Are you sure you want to delete this slot? This will remove it from the website immediately.')) {
                return;
            }
            
            fetch('/pannl/delete_feed.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ feed_key: feedKey })
            })
            .then(response => response.json())
            .then(res => {
                if (res.success) {
                    const card = document.getElementById(`feed-card-${feedKey}`);
                    if (card) {
                        card.remove();
                    }
                    alert('Slot deleted successfully!');
                } else {
                    alert('Error deleting slot: ' + res.message);
                }
            })
            .catch(err => {
                console.error(err);
                alert('Server error deleting slot.');
            });
        }

        function toggleSidebar() {
            const sidebar = document.querySelector('.sidebar');
            sidebar.classList.toggle('active');
        }

        // Active class sidebar menu toggler
        document.addEventListener('DOMContentLoaded', () => {
            const menuItems = document.querySelectorAll('.menu-list .menu-item');
            menuItems.forEach(item => {
                const link = item.querySelector('a');
                if (link && link.getAttribute('href').startsWith('#')) {
                    link.addEventListener('click', () => {
                        menuItems.forEach(i => i.classList.remove('active'));
                        item.classList.add('active');
                        // Close sidebar on mobile after clicking item
                        const sidebar = document.querySelector('.sidebar');
                        if (sidebar.classList.contains('active')) {
                            sidebar.classList.remove('active');
                        }
                    });
                }
            });
        });
    </script>
</body>
</html>
