<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Invoices - WhiteTake</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/Admin/assets/css/style.css" rel="stylesheet">
</head>
<body>
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Invoices</h2>
            <a href="/Admin/admin/create_invoice.php" class="btn btn-primary" style="width: auto; padding: 10px 20px;">
                <i class="bi bi-plus-lg"></i>
            </a>
        </div>

        <% if (invoices && invoices.length > 0) { %>
            <% invoices.forEach(function(inv) { %>
                <div class="card p-3 mb-2">
                    <div class="d-flex justify-content-between">
                        <div>
                            <div class="text-label">To: <%= inv.client_name %></div>
                            <h5 class="mb-1"><%= inv.title %></h5>
                            <div class="text-muted small"><%= new Date(inv.created_at).toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: 'numeric' }) %></div>
                        </div>
                        <div class="text-end">
                            <div class="d-flex flex-column align-items-end">
                                <a href="/Admin/admin/edit_invoice.php?id=<%= inv.id %>" class="btn btn-sm btn-outline-primary mb-2 py-0 px-1">
                                    <i class="bi bi-pencil small"></i>
                                </a>
                                <div class="stat-value" style="font-size: 20px;">₹<%= Number(inv.amount).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
                                <% 
                                let badgeClass = '';
                                if (inv.status === 'paid') badgeClass = 'bg-success';
                                else if (inv.status === 'unpaid') badgeClass = 'bg-danger';
                                else badgeClass = 'bg-warning text-dark';
                                %>
                                <span class="badge <%= badgeClass %>"><%= inv.status.charAt(0).toUpperCase() + inv.status.slice(1) %></span>
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <p class="text-center text-muted mt-5">No invoices found.</p>
        <% } %>
    </div>

    <nav class="bottom-nav">
        <a href="/Admin/admin/dashboard.php" class="nav-item">
            <i class="bi bi-grid"></i>
            <span>Home</span>
        </a>
        <a href="/Admin/admin/clients.php" class="nav-item">
            <i class="bi bi-people"></i>
            <span>Clients</span>
        </a>
        <a href="/Admin/admin/invoices.php" class="nav-item active">
            <i class="bi bi-receipt-fill"></i>
            <span>Invoices</span>
        </a>
        <a href="/Admin/admin/logout.php" class="nav-item">
            <i class="bi bi-box-arrow-right"></i>
            <span>Logout</span>
        </a>
    </nav>
    <script src="/Admin/assets/js/app.js"></script>
</body>
</html>
